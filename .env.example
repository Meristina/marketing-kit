# Marketing-Kit — environment template.  COPY to `.env` and fill in your secrets.
#   cp .env.example .env
# `.env` is gitignored (never committed). Variables here OVERRIDE the shell for this project.

# --- Provider key ---------------------------------------------------------------
# A real OpenAI key (sk-...), OR an OpenRouter key (sk-or-v1-...) with OPENAI_BASE_URL below.
OPENAI_API_KEY=

# --- Provider routing (optional) ------------------------------------------------
# Leave UNSET to hit OpenAI directly. Set to use OpenRouter (or any OpenAI-compatible base):
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# --- Models (grade -> model) ----------------------------------------------------
# Defaults are gpt-5 / gpt-5-mini (OpenAI direct). Via OpenRouter use slugs, e.g. openai/gpt-4o.
# MK_ELITE_MODEL=gpt-5
# MK_STANDARD_MODEL=gpt-5-mini

# --- Web search (provider-agnostic; the brain model is chosen separately) --------
# Soldiers research live facts. OpenAI's hosted search only works on OpenAI's platform, so pick a
# FREE backend with MK_SEARCH — it works with ANY brain (GPT, Claude, OpenRouter, Gemini):
#   MK_SEARCH=ddg     DuckDuckGo  — FREE, no key, no quota (unofficial)     pip install ".[ddg]"
#   MK_SEARCH=tavily  Tavily      — free 1k/mo, LLM-clean   TAVILY_API_KEY  pip install ".[tavily]"
#   MK_SEARCH=gemini  Gemini      — free 1.5k/day           GEMINI_API_KEY  pip install ".[gemini]"
#   MK_SEARCH=openai  OpenAI hosted search (OpenAI brain only)
#   (unset -> auto: TAVILY_API_KEY -> tavily ; else GEMINI_API_KEY -> gemini ; else OpenAI hosted)
# MK_SEARCH=ddg
# TAVILY_API_KEY=
# GEMINI_API_KEY=
# MK_SEARCH_MODEL=gemini-2.5-flash    # model for Gemini grounding (free tier)
# MK_WEBSEARCH=0                      # disable web search entirely

# Gemini AS THE BRAIN too (optional):
#   OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#   OPENAI_API_KEY=<gemini key>  MK_ELITE_MODEL=gemini-2.5-flash  MK_STANDARD_MODEL=gemini-2.5-flash
#   (use -flash, not -pro, to stay on the free tier)

# --- Tracing --------------------------------------------------------------------
# The Agents SDK exports traces to OpenAI's platform; if your key is NOT an OpenAI key
# (e.g. OpenRouter / Gemini), disable it to avoid a noisy 401:
# OPENAI_AGENTS_DISABLE_TRACING=1
