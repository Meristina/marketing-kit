# Marketing-Kit — environment template.  COPY to `.env` and fill in your secrets.
#   cp .env.example .env
# `.env` is gitignored (never committed). Variables here OVERRIDE the shell for this project.

# --- Provider key ---------------------------------------------------------------
# A real OpenAI key (sk-...), OR an OpenRouter key (sk-or-v1-...) with OPENAI_BASE_URL below.
OPENAI_API_KEY=

# --- Provider routing (optional) ------------------------------------------------
# Leave UNSET to hit OpenAI directly. Set to use OpenRouter (or any OpenAI-compatible base):
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# --- Models (grade -> model) ----------------------------------------------------
# Defaults are gpt-5 / gpt-5-mini (OpenAI direct). Via OpenRouter use slugs, e.g. openai/gpt-4o.
# MK_ELITE_MODEL=gpt-5
# MK_STANDARD_MODEL=gpt-5-mini

# --- Web search (provider-agnostic, powered by Gemini) --------------------------
# Soldiers research live facts. OpenAI's hosted web search only works on OpenAI's platform;
# a Gemini key (Google AI Studio) gives every soldier Google-Search grounding with ANY brain.
#   pip install ".[gemini]"
# GEMINI_API_KEY=                       # set -> web search runs via Gemini grounding
# MK_SEARCH_MODEL=gemini-2.5-flash      # model used for the grounded search
# MK_WEBSEARCH=0                        # set to 0 to disable web search entirely

# Two common setups:
#   (A) GPT/Claude/OpenRouter brain + Gemini search:  OPENAI_API_KEY=... (+ OPENAI_BASE_URL) and GEMINI_API_KEY=...
#   (B) Gemini brain + Gemini search:                 OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#                                                      OPENAI_API_KEY=<gemini key>  MK_ELITE_MODEL=gemini-2.5-pro
#                                                      MK_STANDARD_MODEL=gemini-2.5-flash  GEMINI_API_KEY=<same key>

# --- Tracing --------------------------------------------------------------------
# The Agents SDK exports traces to OpenAI's platform; if your key is NOT an OpenAI key
# (e.g. OpenRouter / Gemini), disable it to avoid a noisy 401:
# OPENAI_AGENTS_DISABLE_TRACING=1
